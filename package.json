  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260717.1",
    "@playwright/test": "^1.61.1",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^4.7.0",
    "typescript": "^5.9.2",
    "vite": "^7.2.4",
    "vitest": "^3.2.4",
    "wrangler": "^4.112.0"
